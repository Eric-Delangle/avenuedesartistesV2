{% extends 'base.html.twig' %}

{% block title %}Abonnement Artiste — Avenue des Artistes{% endblock %}

{% block body %}
<div class="container mt-5 mb-5" style="max-width: 680px;">

    <div class="text-center mb-5">
        <h1 style="font-family: var(--font-display); font-size: 2rem; color: var(--text-dark);">
            Vendez vos œuvres sur le marché
        </h1>
        <p class="text-muted">Un abonnement simple, sans commission sur vos ventes.</p>
    </div>

    {% if has_subscription %}
        {# — Abonnement actif — #}
        <div class="card border-0 shadow-sm p-4 text-center">
            <div style="font-size: 3rem; margin-bottom: 12px;">✅</div>
            <h3 style="font-family: var(--font-display); color: var(--primary);">Abonnement actif</h3>
            <p class="text-muted mt-2">
                Actif depuis le {{ subscription.startedAt|date('d/m/Y') }}
                {% if subscription.endsAt %}
                    · Renouvellement le {{ subscription.endsAt|date('d/m/Y') }}
                {% endif %}
            </p>
            <p class="mt-3">Vous pouvez mettre autant d'œuvres en vente que vous souhaitez.</p>

            <form method="post" action="{{ path('subscription_cancel') }}" class="mt-4"
                  onsubmit="return confirm('Annuler votre abonnement ? Il restera actif jusqu\'à la fin de la période en cours.')">
                <button type="submit" class="btn btn-outline-danger btn-sm">
                    Annuler l'abonnement
                </button>
            </form>
        </div>

    {% else %}
        {# — Page d'offre — #}
        <div class="card border-0 shadow-sm overflow-hidden">
            <div style="background: linear-gradient(135deg, #1a1a2e, #0f3460); padding: 36px; text-align: center;">
                <span style="font-size: 2.5rem;">🎨</span>
                <h2 style="font-family: var(--font-display); color: #fff; margin: 12px 0 4px;">Plan Artiste</h2>
                <div style="font-size: 2.8rem; font-weight: 700; color: #2fa4e7; line-height: 1;">
                    4,99 €<span style="font-size: 1rem; color: rgba(255,255,255,0.6); font-weight: 400;">/mois</span>
                </div>
            </div>

            <div class="p-4">
                <ul style="list-style: none; padding: 0; margin: 0 0 28px;">
                    {% for feature in [
                        'Œuvres en vente illimitées sur la Marketplace',
                        'Aucune commission sur vos ventes',
                        'Les échanges restent toujours gratuits',
                        'Annulation à tout moment'
                    ] %}
                        <li class="d-flex align-items-center mb-3">
                            <span style="color: #28a745; font-size: 1.1rem; margin-right: 10px;">✓</span>
                            <span>{{ feature }}</span>
                        </li>
                    {% endfor %}
                </ul>

                <form method="post" action="{{ path('subscription_checkout') }}">
                    <button type="submit" class="btn btn-primary btn-block" style="padding: 14px; font-size: 1rem;">
                        <i class="fas fa-lock"></i> S'abonner — 4,99 €/mois
                    </button>
                </form>

                <p class="text-muted text-center mt-3" style="font-size: 0.82rem;">
                    Paiement sécurisé par Stripe · Annulable à tout moment
                </p>
            </div>
        </div>
    {% endif %}

</div>
{% endblock %}
