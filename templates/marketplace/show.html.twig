{% extends 'base.html.twig' %}

{% block title %}{{ work.name }}{% if work.gallery and work.gallery.user %} par {{ work.gallery.user.firstName|capitalize }} {{ work.gallery.user.lastName|capitalize }}{% endif %} — Avenue des Artistes{% endblock %}
{% block meta_description %}{{ work.description ? work.description|slice(0,155) : work.name ~ ' — œuvre originale disponible sur Avenue des Artistes.' }}{% endblock %}
{% block og_type %}product{% endblock %}
{% block og_image %}{% if work.picture %}{{ app.request.schemeAndHttpHost }}/images/artisticWorks/{{ work.picture }}{% else %}{{ app.request.schemeAndHttpHost }}/images/favicon.svg{% endif %}{% endblock %}
{% block canonical %}{{ url('marketplace_show', {'id': work.id}) }}{% endblock %}

{% block body %}
<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('marketplace_index') }}">Marketplace</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ work.name }}</li>
        </ol>
    </nav>

    <div class="row">
        {# Photo #}
        <div class="col-md-6">
            {% if work.picture %}
                <img src="{{ asset('images/artisticWorks/' ~ work.picture) }}"
                     class="img-fluid rounded shadow"
                     alt="{{ work.name }}">
            {% else %}
                <div class="bg-light rounded d-flex align-items-center justify-content-center"
                     style="height: 400px;">
                    <i class="fas fa-image fa-5x text-muted"></i>
                </div>
            {% endif %}
        </div>

        {# Détails #}
        <div class="col-md-6">
            <h1 class="mb-3">{{ work.name }}</h1>

            <div class="mb-3">
                {% if work.listingType in ['sale', 'both'] %}
                    <span class="badge badge-success badge-pill">Vente</span>
                {% endif %}
                {% if work.listingType in ['exchange', 'both'] %}
                    <span class="badge badge-info badge-pill">Échange</span>
                {% endif %}
            </div>

            {% if work.price is not null %}
                <p class="h3 text-success mb-3">{{ work.price|number_format(2, ',', ' ') }} €</p>
            {% else %}
                <p class="text-muted font-italic mb-3">Prix sur échange</p>
            {% endif %}

            {% if work.description %}
                <p class="card-text">{{ work.description }}</p>
            {% endif %}

            {% if work.listingType in ['exchange', 'both'] and work.exchangeDescription %}
                <div class="alert alert-info mt-3">
                    <strong>Conditions d'échange :</strong><br>
                    {{ work.exchangeDescription }}
                </div>
            {% endif %}

            {% if work.category %}
                <p class="text-muted">
                    <i class="fas fa-tag"></i> Catégorie : {{ work.category.name }}
                </p>
            {% endif %}

            {% if work.gallery %}
                <p class="text-muted">
                    <i class="fas fa-store-alt"></i>
                    Galerie :
                    <a href="{{ path('galery_showUser', {'id': work.gallery.id}) }}">
                        {{ work.gallery.name ?? 'Voir la galerie' }}
                    </a>
                </p>
            {% endif %}

            <div class="mt-4">
                {% if app.user is null %}
                    <a href="{{ path('security_login') }}" class="btn btn-primary btn-block">
                        <i class="fas fa-handshake"></i> Faire une offre (connexion requise)
                    </a>
                {% elseif offerForm is null %}
                    <div class="alert alert-info">
                        <i class="fas fa-info-circle"></i> Vous ne pouvez pas faire d'offre sur votre propre œuvre.
                    </div>
                {% else %}
                    <button class="btn btn-primary btn-block" type="button" data-toggle="collapse" data-target="#offerFormPanel" aria-expanded="false">
                        <i class="fas fa-handshake"></i> Faire une offre
                    </button>
                    <div class="collapse mt-3" id="offerFormPanel">
                        <div class="card card-body border-0 shadow-sm">
                            <h5 class="mb-3" style="font-family: var(--font-display);">Votre offre</h5>
                            {{ form_start(offerForm, {'attr': {'novalidate': 'novalidate'}}) }}
                                {% if offerForm.type is defined and offerForm.type.vars.choices|length > 1 %}
                                    <div class="form-group">
                                        {{ form_label(offerForm.type) }}
                                        {{ form_widget(offerForm.type) }}
                                    </div>
                                {% else %}
                                    {{ form_widget(offerForm.type) }}
                                {% endif %}

                                <div id="purchase-fields" class="form-group">
                                    {{ form_label(offerForm.offerPrice) }}
                                    {{ form_widget(offerForm.offerPrice, {'attr': {'class': 'form-control'}}) }}
                                    {{ form_errors(offerForm.offerPrice) }}
                                </div>

                                <div id="exchange-fields" class="form-group">
                                    {{ form_label(offerForm.proposedWork) }}
                                    {{ form_widget(offerForm.proposedWork, {'attr': {'class': 'form-control'}}) }}
                                    {{ form_errors(offerForm.proposedWork) }}
                                </div>

                                <div class="form-group">
                                    {{ form_label(offerForm.offerMessage) }}
                                    {{ form_widget(offerForm.offerMessage, {'attr': {'class': 'form-control'}}) }}
                                </div>

                                <button type="submit" class="btn btn-success btn-block">
                                    <i class="fas fa-paper-plane"></i> Envoyer l'offre
                                </button>
                            {{ form_end(offerForm) }}
                        </div>
                    </div>
                {% endif %}
                <a href="{{ path('marketplace_index') }}" class="btn btn-outline-secondary btn-block mt-2">
                    Retour à la marketplace
                </a>
            </div>

            {% block javascripts %}
                {{ parent() }}
                <script>
                (function() {
                    var typeRadios = document.querySelectorAll('[name*="[type]"]');
                    var purchaseFields = document.getElementById('purchase-fields');
                    var exchangeFields = document.getElementById('exchange-fields');

                    function updateFields() {
                        var val = document.querySelector('[name*="[type]"]:checked')?.value
                            || document.querySelector('[name*="[type]"]')?.value;
                        if (!val) return;
                        purchaseFields.style.display  = val === 'purchase'  ? '' : 'none';
                        exchangeFields.style.display  = val === 'exchange'  ? '' : 'none';
                    }

                    typeRadios.forEach(function(r){ r.addEventListener('change', updateFields); });
                    updateFields();
                })();
                </script>
            {% endblock %}
        </div>
    </div>
</div>

<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "{{ work.name|e('js') }}",
    {% if work.description %}"description": "{{ work.description|slice(0,200)|e('js') }}",{% endif %}
    {% if work.picture %}"image": "{{ app.request.schemeAndHttpHost }}/images/artisticWorks/{{ work.picture }}",{% endif %}
    "url": "{{ url('marketplace_show', {'id': work.id}) }}",
    {% if work.price %}"offers": {
        "@type": "Offer",
        "priceCurrency": "EUR",
        "price": "{{ work.price }}",
        "availability": "https://schema.org/InStock"
    },{% endif %}
    {% if work.gallery and work.gallery.user %}"seller": {
        "@type": "Person",
        "name": "{{ work.gallery.user.firstName|capitalize|e('js') }} {{ work.gallery.user.lastName|capitalize|e('js') }}"
    }{% endif %}
}
</script>
{% endblock %}
