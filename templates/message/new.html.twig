{% extends 'base.html.twig' %}

{% block title %}Nouveau message | Art et partage{% endblock %}

{% block body %}
<section class="container mt-5 mb-5" style="max-width:700px;">

    {% if app.user %}
        <h1 class="text-center mb-5" style="color:#2c3e50;font-weight:700;">Rédigez votre message</h1>

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body p-4">
                {{ include('message/_form.html.twig') }}
            </div>
        </div>

        <div class="d-flex justify-content-center">
            <a href="{{ path('message_index', {'id': app.user.id}) }}" class="btn btn-lg" style="background-color:#6c757d;color:white;border-radius:30px;padding:10px 25px;">
                Retour à vos messages
            </a>
        </div>

    {% else %}
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body p-4 text-center">
                <p class="mb-4">Vous devez être inscrit et connecté pour envoyer des messages.</p>
                <a href="{{ path('home') }}" class="btn btn-lg" style="background-color:#e67e22;color:white;border-radius:30px;padding:10px 25px;">
                    Retour à l'accueil
                </a>
            </div>
        </div>
    {% endif %}

</section>
{% endblock %}
