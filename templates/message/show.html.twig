{% extends 'base.html.twig' %}

{% block title %}Message | Art et partage{% endblock %}

{% block body %}
<section class="container mt-5 mb-5" style="max-width: 700px;">

    <h1 class="text-center mb-4" style="color: #2c3e50; font-weight: 700;">Message reçu</h1>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-4">
            <div class="mb-3">
                <span style="color:#e67e22; font-weight:600;">De :</span>
                {{ message.expediteur.firstName }}
            </div>
            <div class="mb-3">
                <span style="color:#e67e22; font-weight:600;">Titre :</span>
                {{ message.titre }}
            </div>
            <div class="mb-3">
                <span style="color:#e67e22; font-weight:600;">Message :</span>
                <p class="mt-2">{{ message.message }}</p>
            </div>
            <div>
                <span style="color:#e67e22; font-weight:600;">Posté le :</span>
                {{ message.postedAt ? message.postedAt|date('d-m-Y H:i') : '' }}
            </div>
        </div>
    </div>

    {% if reponses is defined and reponses|length > 0 %}
    <h3 class="mb-3 text-center" style="color:#2c3e50;">Réponses</h3>
    {% for rep in reponses %}
    <div class="card shadow-sm border-0 mb-3">
        <div class="card-body p-3">
            <p class="mb-1"><strong>{{ rep.expediteur.firstName }}</strong> <small class="text-muted">— {{ rep.postedAt|date('d-m-Y H:i') }}</small></p>
            <p class="mb-0">{{ rep.message }}</p>
        </div>
    </div>
    {% endfor %}
    {% endif %}

    <div class="d-flex justify-content-center gap-4 mt-4 flex-wrap">
        <a class="btn btn-lg" href="{{ path('reponse_new', {'id': message.id}) }}" style="background-color:#e67e22;color:white;border-radius:30px;padding:10px 30px;margin:0 10px;">
            Répondre
        </a>
        <a class="btn btn-lg" href="{{ path('message_index', {'id': app.user.id}) }}" style="background-color:#2fa4e7;color:white;border-radius:30px;padding:10px 30px;margin:0 10px;">
            Retour aux messages
        </a>
        <form method="post" action="{{ path('message_delete', {'id': message.id}) }}" onsubmit="return confirm('Voulez vous vraiment supprimer ce message ?');">
            <input type="hidden" name="_method" value="DELETE">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ message.id) }}">
            <button class="btn btn-lg" style="background-color:#dc3545;color:white;border-radius:30px;padding:10px 30px;margin:0 10px;">
                Supprimer
            </button>
        </form>
    </div>

</section>
{% endblock %}