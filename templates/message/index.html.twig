{% extends 'base.html.twig' %}

{% block title %}Vos messages | Art et partage{% endblock %}

{% block body %}
<section class="container mt-5 mb-5" style="max-width:800px;">

    <h1 class="text-center mb-5" style="color:#2c3e50;font-weight:700;">Vos messages</h1>

    <div class="card shadow-sm border-0 mb-5">
        <div class="card-body p-4">
            <h2 class="mb-4" style="color:#e67e22;font-size:1.3rem;">📨 Messages reçus</h2>
            {% if messages %}
                {% for msg in messages %}
                <div class="d-flex justify-content-between align-items-center p-3 mb-2" style="background:#f8f9fa;border-radius:10px;">
                    <div>
                        <strong>{{ msg.expediteur ? msg.expediteur.firstName|capitalize ~ ' ' ~ msg.expediteur.lastName|capitalize : 'Inconnu' }}</strong>
                        <p class="mb-0 text-muted" style="font-size:.9rem;">{{ msg.titre }}</p>
                        <small class="text-muted">{{ msg.postedAt ? msg.postedAt|date('d/m/Y H:i') : '' }}</small>
                    </div>
                    <a href="{{ path('message_show', {'id': msg.id}) }}" class="btn btn-sm" style="background:#2fa4e7;color:white;border-radius:20px;">Lire</a>
                </div>
                {% endfor %}
            {% else %}
                <p class="text-muted">Aucun message reçu.</p>
            {% endif %}
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-5">
        <div class="card-body p-4">
            <h2 class="mb-4" style="color:#e67e22;font-size:1.3rem;">📤 Messages envoyés</h2>
            {% if message %}
                {% for msg in message %}
                <div class="d-flex justify-content-between align-items-center p-3 mb-2" style="background:#f8f9fa;border-radius:10px;">
                    <div>
                        <strong>{{ msg.destinataire ? msg.destinataire.firstName|capitalize ~ ' ' ~ msg.destinataire.lastName|capitalize : 'Inconnu' }}</strong>
                        <p class="mb-0 text-muted" style="font-size:.9rem;">{{ msg.titre }}</p>
                        <small class="text-muted">{{ msg.postedAt ? msg.postedAt|date('d/m/Y H:i') : '' }}</small>
                    </div>
                    <a href="{{ path('message_show', {'id': msg.id}) }}" class="btn btn-sm" style="background:#2fa4e7;color:white;border-radius:20px;">Voir</a>
                </div>
                {% endfor %}
            {% else %}
                <p class="text-muted">Aucun message envoyé.</p>
            {% endif %}
        </div>
    </div>

    <div class="text-center mt-4">
        <a href="{{ path('member_index') }}" class="btn btn-lg" style="background-color:#e67e22;color:white;border-radius:30px;padding:10px 30px;">
            Retour à votre espace
        </a>
    </div>

</section>
{% endblock %}