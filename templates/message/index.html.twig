{% extends 'base.html.twig' %}

{% block title %}Vos messages{% endblock %}

{% block body %}
<div class="container white liens_blancs mt-5">
    <h1 class="text-center massenet font_grand">Vos messages</h1>

    <h2 class="massenet mt-4">Messages reçus</h2>
    {% if messages %}
        <table class="table text-center mt-3">
            <thead>
                <tr>
                    <th>De</th>
                    <th>Titre</th>
                    <th>Date</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                {% for msg in messages %}
                <tr>
                    <td>{{ msg.expediteur ? msg.expediteur.firstName|capitalize ~ ' ' ~ msg.expediteur.lastName|capitalize : 'Inconnu' }}</td>
                    <td>{{ msg.titre }}</td>
                    <td>{{ msg.postedAt ? msg.postedAt|date('d/m/Y H:i') : '' }}</td>
                    <td>
                        <a href="{{ path('message_show', {'id': msg.id}) }}" class="btn btn-sm btn-info">Lire</a>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p class="mt-3">Aucun message reçu.</p>
    {% endif %}

    <h2 class="massenet mt-5">Messages envoyés</h2>
    {% if message %}
        <table class="table text-center mt-3">
            <thead>
                <tr>
                    <th>À</th>
                    <th>Titre</th>
                    <th>Date</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                {% for msg in message %}
                <tr>
                    <td>{{ msg.destinataire ? msg.destinataire.firstName|capitalize ~ ' ' ~ msg.destinataire.lastName|capitalize : 'Inconnu' }}</td>
                    <td>{{ msg.titre }}</td>
                    <td>{{ msg.postedAt ? msg.postedAt|date('d/m/Y H:i') : '' }}</td>
                    <td>
                        <a href="{{ path('message_show', {'id': msg.id}) }}" class="btn btn-sm btn-info">Voir</a>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p class="mt-3">Aucun message envoyé.</p>
    {% endif %}

    <div class="text-center mt-4">
        <a href="{{ path('member_index') }}" class="btn bouton white lien">Retour à votre espace</a>
    </div>
</div>

<script>
    document.getElementById('inscription').style.display = 'none';
    document.getElementById('connexion').style.display = 'none';
    document.getElementById('admin').style.display = 'none';
    document.getElementById('member').style.display = 'none';
    document.getElementById('bleudeco').style.display = 'none';
    document.getElementById('deco').style.display = 'block';
    document.getElementById('deconnexion').style.display = 'block';
    document.getElementById('achats').style.display = 'block';
    document.getElementById('echanges').style.display = 'block';
    document.getElementById('achat').style.display = 'none';
    document.getElementById('echange').style.display = 'none';
    document.getElementById('pas_vu').style.display = 'block';
</script>
{% if is_granted('ROLE_ADMIN') %}
<script>
    document.getElementById('admin').style.display = 'block';
</script>
{% endif %}
{% endblock %}
