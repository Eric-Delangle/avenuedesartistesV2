{% extends 'base.html.twig' %}

{% block title %}Avenue des Artistes | Achetez, vendez et échangez des œuvres d'art{% endblock %}
{% block meta_description %}Rejoignez Avenue des Artistes : la plateforme française pour vendre, acheter et échanger des œuvres d'art originales. Peinture, sculpture, dessin, photographie, céramique. 0% de commission.{% endblock %}

{% block body %}

<!-- HERO -->
<section class="hero-section">
	<div class="hero-overlay"></div>
	<div class="container hero-content">
		<h1 class="hero-title">L'art circule <br>entre ceux qui l'aiment.</h1>
		<p class="hero-subtitle">Vendez, échangez et découvrez des œuvres uniques créées par des artistes près de chez vous.</p>
		<div class="hero-actions">
			<a href="{{ path('marketplace_index') }}" class="btn btn-hero-primary">Explorer le marketplace</a>
			<a href="{{ path('share_index') }}" class="btn btn-hero-secondary">Proposer un échange</a>
		</div>
	</div>
</section>

<!-- CARTE + INFO -->
<section class="map-section">
	<div class="container">
		<div class="section-header">
			<h2 class="section-title">Les artistes près de vous</h2>
			<p class="section-subtitle">Cliquez sur une punaise pour découvrir un artiste</p>
		</div>
		<div class="map-wrapper">
			<div id="map"></div>
			<div id="infoMember" class="map-info-card">
				<ul id="listeInfos" class="no_point">
					<li><span id="nomMembre"></span></li>
					<li><span id="categorie"></span></li>
					<li><span id="ville"></span></li>
					<li><span id="profil"></span></li>
				</ul>
			</div>
		</div>
	</div>
</section>

<!-- FEATURES -->
<section class="features-section">
	<div class="container">
		<div class="row">
			<div class="col-md-4">
				<div class="feature-card">
					<div class="feature-icon">🎨</div>
					<h3>Partagez votre art</h3>
					<p>Créez votre galerie en quelques minutes et montrez vos œuvres à une communauté passionnée.</p>
				</div>
			</div>
			<div class="col-md-4">
				<div class="feature-card feature-card--accent">
					<div class="feature-icon">🤝</div>
					<h3>Échangez directement</h3>
					<p>Proposez l'une de vos œuvres en échange d'une autre. Sans intermédiaire, sans commission.</p>
				</div>
			</div>
			<div class="col-md-4">
				<div class="feature-card">
					<div class="feature-icon">🛒</div>
					<h3>Vendez sans frais</h3>
					<p>Mettez vos œuvres en vente sur le marketplace. 0% de commission, 100% pour vous.</p>
				</div>
			</div>
		</div>
	</div>
</section>

{% endblock %}
