{% extends 'base.html.twig' %}

{% block title %}Galeries {{ category.name }} | Art et partage{% endblock %}
{% block meta_description %}Parcourez les galeries d'artistes spécialisés en {{ category.name }} sur Avenue des Artistes.{% endblock %}

{% block body %}
<section class="container mt-5 mb-5" style="max-width:800px;">

    <h1 class="text-center mb-5" style="color:#2c3e50;font-weight:700;">
        Galeries — {{ category.name }}
    </h1>

    {% for gallerie in galleries %}
    <div class="card shadow-sm border-0 mb-5">
        <div class="card-body p-4">

            <div class="text-center mb-3">
                <p><span style="color:#e67e22;font-weight:600;">Galerie :</span> {{ gallerie.name }}</p>
                <p><span style="color:#e67e22;font-weight:600;">Membre :</span> {{ gallerie.user.firstName|title }} {{ gallerie.user.lastName|title }}</p>
                <p><span style="color:#e67e22;font-weight:600;">Ville :</span> {{ gallerie.user.location|title }}</p>
            </div>

            <h5 class="text-center mb-4" style="color:#e67e22;">Œuvres</h5>

            {% for artisticWork in gallerie.artisticWorks %}
            <div class="text-center mb-4">
                <img src="{{ asset(['images/artisticWorks/', artisticWork.picture]|join) }}" style="max-width:350px;width:100%;border-radius:10px;margin-bottom:10px;">
                <p><strong>{{ artisticWork.name|title }}</strong></p>
                <p class="text-muted">{{ artisticWork.description }}</p>
            </div>
            {% endfor %}

            <div class="d-flex justify-content-center flex-wrap mt-3">
                <a href="{{ path('message_newUserMess', {'id': gallerie.user.id}) }}" class="btn btn-lg" style="background-color:#e67e22;color:white;border-radius:30px;padding:10px 25px;margin:5px 10px;">
                    Envoyer un message à {{ gallerie.user.firstName|title }}
                </a>
                <a href="{{ path('user_show', {'slug': gallerie.user.slug}) }}" class="btn btn-lg" style="background-color:#2fa4e7;color:white;border-radius:30px;padding:10px 25px;margin:5px 10px;">
                    Voir son profil
                </a>
            </div>
        </div>
    </div>
    {% endfor %}

    <div class="text-center mt-3">
        {{ knp_pagination_render(galleries) }}
    </div>

</section>
{% endblock %}