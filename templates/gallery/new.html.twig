{% extends 'base.html.twig' %}

{% block title %}Créer une galerie | Art et partage{% endblock %}

{% block body %}
<section class="container mt-5 mb-5" style="max-width:700px;">

    <h1 class="text-center mb-5" style="color:#2c3e50;font-weight:700;">Créer une galerie</h1>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-4">
            {{ include('gallery/_form.html.twig') }}
        </div>
    </div>

    <div class="d-flex justify-content-center flex-wrap">
        <a href="{{ path('galery_index', {'id': app.user.id}) }}" class="btn btn-lg" style="background-color:#6c757d;color:white;border-radius:30px;padding:10px 25px;margin:5px 10px;">
            Retour à vos galeries
        </a>
    </div>

</section>
{% endblock %}