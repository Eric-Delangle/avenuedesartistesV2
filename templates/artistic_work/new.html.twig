{% extends 'base.html.twig' %}

{% set is_sale = gallery.galleryType in ['sale', 'mixed'] %}
{% block title %}Ajouter une image à votre galerie {% if is_sale %}de vente{% else %}d'échange{% endif %}{% endblock %}

{% block body %}
	<div class="container">
		<h1 class="text-center mt-5">
			Ajouter une image à votre galerie {% if is_sale %}de vente{% else %}d'échange{% endif %}.
		</h1>

		{{ include('artistic_work/_form.html.twig') }}

		<button class="btn bouton mt-2">
			<a href="{{ path('galery_index', {'id': gallery.id}) }}" style="color:#ffffff; text-decoration:none;">Retour à vos galeries</a>
		</button>
	</div>

{% endblock %}
