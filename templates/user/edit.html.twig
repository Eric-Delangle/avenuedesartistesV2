{% extends 'base.html.twig' %}

{% block title %}Modifier votre profil | Art et partage{% endblock %}

{% block body %}
<section class="container mt-5 mb-5" style="max-width:700px;">

    <h1 class="text-center mb-5" style="color:#2c3e50;font-weight:700;">Modifier votre profil</h1>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-4">
            {{ form_start(form) }}
            {{ form_row(form.firstName, {'attr': {'placeholder': "Votre prénom"}}) }}
            {{ form_row(form.lastName, {'attr': {'placeholder': "Votre nom"}}) }}
            {{ form_row(form.location, {'attr': {'placeholder': "Votre ville"}}) }}
            {{ form_row(form.email, {'attr': {'placeholder': "Votre email"}}) }}
            {{ form_rest(form) }}
            <div class="text-center mt-3">
                <button type="submit" class="btn btn-lg" style="background-color:#e67e22;color:white;border-radius:30px;padding:10px 30px;">
                    Valider
                </button>
            </div>
            {{ form_end(form) }}
        </div>
    </div>

    <div class="d-flex justify-content-center flex-wrap">
        <a href="{{ path('member_index') }}" class="btn btn-lg" style="background-color:#2fa4e7;color:white;border-radius:30px;padding:10px 25px;margin:5px 10px;">
            Retour à votre espace
        </a>
        <a href="{{ path('reset_pass') }}" class="btn btn-lg" style="background-color:#6c757d;color:white;border-radius:30px;padding:10px 25px;margin:5px 10px;">
            Changer de mot de passe
        </a>
        <a href="{{ path('edit_avatar', {'id': user.id}) }}" class="btn btn-lg" style="background-color:#6c757d;color:white;border-radius:30px;padding:10px 25px;margin:5px 10px;">
            Changer votre photo de profil
        </a>
        {{ include('user/_delete_form.html.twig') }}
    </div>

</section>
{% endblock %}