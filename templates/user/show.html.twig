{% extends 'base.html.twig' %}

{% block title %}Profil de {{ user.firstName }} {{ user.lastName }} | Art et partage{% endblock %}

{% block body %}
<section class="container mt-5 mb-5" style="max-width:800px;">

    <h1 class="text-center mb-5" style="color:#2c3e50;font-weight:700;">
        Profil de {{ user.firstName }} {{ user.lastName }}
    </h1>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-4 text-center">
            <img src="{{ asset(['images/avatars/', user.avatar]|join) }}" alt="avatar" style="width:100px;height:100px;border-radius:50%;object-fit:cover;margin-bottom:15px;">
            <h2 style="color:#2c3e50;font-weight:700;">{{ user.firstName }} {{ user.lastName }}</h2>
            <p class="text-muted">{{ user.location }}</p>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-4 text-center">
            <h5 style="color:#e67e22;">Description</h5>
            <p>{{ user.description2 ?: 'Aucune description.' }}</p>

            <h5 style="color:#e67e22;" class="mt-3">📬 Contact</h5>
            <p>{{ user.email }}</p>

            {% if user.website %}
            <h5 style="color:#e67e22;" class="mt-3">🌐 Site internet</h5>
            <p><a href="{{ user.website }}" target="_blank" rel="noopener">{{ user.website }}</a></p>
            {% endif %}

            <h5 style="color:#e67e22;" class="mt-3">Catégories</h5>
            <p>
                {% for item in user.categories %}
                    {% if not loop.first %}, {% endif %}{{ item }}
                {% endfor %}
            </p>

            <h5 style="color:#e67e22;" class="mt-3">Galeries d'échange</h5>
            {% if galleryechange %}
                <div class="d-flex flex-wrap justify-content-center gap-2 mt-2">
                    {% for item in galleryechange %}
                        <a href="{{ path('galery_showUser', {'id': item.id}) }}" class="btn btn-sm" style="background-color:#e67e22;color:white;border-radius:20px;">
                            {{ item }}
                        </a>
                    {% endfor %}
                </div>
            {% else %}
                <p class="text-muted">Ce membre ne possède pas encore de galerie d'échange.</p>
            {% endif %}
        </div>
    </div>

    <div class="d-flex justify-content-center flex-wrap">
        <a href="{{ path('message_newUserMess', {'id': user.id}) }}" class="btn btn-lg" style="background-color:#e67e22;color:white;border-radius:30px;padding:10px 25px;margin:5px 10px;">
            Envoyer un message
        </a>
        <a href="{{ path('home') }}" class="btn btn-lg" style="background-color:#6c757d;color:white;border-radius:30px;padding:10px 25px;margin:5px 10px;">
            Retour à l'accueil
        </a>
    </div>

</section>
{% endblock %}