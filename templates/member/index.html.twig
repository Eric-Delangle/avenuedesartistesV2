{% extends 'base.html.twig' %}

{% block title %}Votre espace | Art et partage{% endblock %}

{% block body %}
<section class="container mt-5 mb-5" style="max-width:800px;">

    <h1 class="text-center mb-4" style="color:#2c3e50;font-weight:700;">Votre espace, {{ app.user.firstName|capitalize }}</h1>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-4 text-center">
            <img src="{{ asset(['images/avatars/', app.user.avatar]|join) }}" alt="avatar" style="width:100px;height:100px;border-radius:50%;object-fit:cover;margin-bottom:15px;">
            <h2 style="color:#2c3e50;font-weight:700;">{{ app.user.firstName|capitalize }} {{ app.user.lastName|capitalize }}</h2>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-4 text-center">
            <h5 style="color:#e67e22;">📍 Adresse</h5>
            <p>{{ app.user.adress }} {{ app.user.postalCode }} — {{ app.user.location|capitalize }}</p>

            <h5 style="color:#e67e22;" class="mt-3">Description</h5>
            <p>{{ app.user.description2 ?: 'Aucune description.' }}</p>

            <h5 style="color:#e67e22;" class="mt-3">📬 Contact</h5>
            <p><i class="fas fa-envelope mr-2"></i> {{ app.user.email }}</p>
            <p><i class="fas fa-phone-volume mr-2"></i> {{ app.user.tel ?: 'Non renseigné' }}</p>

            <h5 style="color:#e67e22;" class="mt-3">Catégories</h5>
            <p>
                {% for item in app.user.categories %}
                    {% if not loop.first %}, {% endif %}{{ item }}
                {% endfor %}
            </p>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-4">
            <h5 style="color:#e67e22;" class="mb-4">⚙️ Actions</h5>
            <div class="d-flex flex-wrap justify-content-center">
                <a href="{{ path('galery_index', {'id': app.user.id}) }}" class="btn btn-lg" style="background-color:#e67e22;color:white;border-radius:30px;padding:10px 25px;">
                    Gérer vos galeries
                </a>
                <a href="{{ path('galery_new', {'id': app.user.id}) }}" class="btn btn-lg" style="background-color:#e67e22;color:white;border-radius:30px;padding:10px 25px;margin: 5px 10px;">
                    Créer une galerie
                </a>
                <a href="{{ path('message_index', {'id': app.user.id}) }}" class="btn btn-lg" style="background-color:#2fa4e7;color:white;border-radius:30px;padding:10px 25px;margin: 5px 10px;">
                    Consulter vos messages
                    {% if nbMessages > 0 %}
                        <span style="background:red;color:white;border-radius:50%;padding:2px 7px;font-size:0.8em;">{{ nbMessages }}</span>
                    {% endif %}
                </a>
                <a href="{{ path('user_edit', {'id': app.user.id}) }}" class="btn btn-lg" style="background-color:#2fa4e7;color:white;border-radius:30px;padding:10px 25px;margin: 5px 10px;">
                    Modifier mes informations
                </a>
               <a href="{{ path('reset_pass') }}" class="btn btn-lg" style="background-color:#6c757d;color:white;border-radius:30px;padding:10px 25px;margin: 5px 10px;">
                    Changer mon mot de passe
                </a>
            </div>
        </div>
    </div>

    <div class="text-center mt-3">
        <form method="post" action="{{ path('user_delete', {'id': app.user.id}) }}" onsubmit="return confirm('Vous êtes sûr(e) de vouloir supprimer votre compte ?');">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ app.user.id) }}">
            <button type="submit" class="btn btn-lg" style="background-color:#dc3545;color:white;border-radius:30px;padding:10px 25px;">
                Supprimer mon compte
            </button>
        </form>
    </div>

</section>
{% endblock %}