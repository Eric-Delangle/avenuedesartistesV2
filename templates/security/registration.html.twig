{% extends 'base.html.twig' %}

{% block title %}Créer votre compte | Art et partage{% endblock %}

{% block meta_description %}Rejoignez Art et partage et commencez à échanger vos œuvres d'art gratuitement.{% endblock %}

{% form_theme form 'bootstrap_4_layout.html.twig' %}

{% block body %}
<div class="container mt-5 mb-5" style="min-height: calc(100vh - 200px);">
    <h1 class="titre text-center mb-2">Créer votre <span class="A_titre">c</span>ompte</h1>
    <p class="text-center text-muted mb-5">Rejoignez la communauté et échangez vos œuvres gratuitement.</p>

    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-6">
            <div class="card p-4 p-md-5">
                {{ form_start(form, {'attr': {'class': 'placeho'}}) }}

                {{ form_row(form.firstName, {'attr': {'placeholder': "Votre prénom"}}) }}
                {{ form_row(form.lastName,  {'attr': {'placeholder': "Votre nom"}}) }}
                {{ form_row(form.location,  {'attr': {'placeholder': "Votre ville"}}) }}
                {{ form_row(form.email,     {'attr': {'placeholder': "Votre email"}}) }}
                {{ form_row(form.password,  {'attr': {'placeholder': "Votre mot de passe"}}) }}
                {{ form_row(form.password_verify) }}
                {{ form_rest(form) }}
                <input type="hidden" name="recaptcha_token" id="recaptcha_token">
                <div class="mt-4">
                    <button type="submit" class="btn btn-info bouton btn-block">Créer mon compte</button>
                </div>

                <p class="text-center text-muted mt-3" style="font-size: 0.9rem;">
                    Déjà membre ? <a href="{{ path('security_login') }}">Connectez-vous</a>
                </p>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>

<script>
document.querySelector('.placeho').addEventListener('submit', function(e) {
    e.preventDefault();
    var form = this;
    grecaptcha.ready(function() {
        grecaptcha.execute('6LcVueEsAAAAAFwxyx6grNYVGQeIwHmorWsDvjXf', {action: 'register'})
            .then(function(token) {
                document.getElementById('recaptcha_token').value = token;
                form.submit();
            });
    });
});
document.getElementById('inscription').style.display = 'none';
document.getElementById('connexion').style.display = 'none';
document.getElementById('admin').style.display = 'none';
document.getElementById('member').style.display = 'none';
document.getElementById('deconnexion').style.display = 'none';
document.getElementById('achats').style.display = 'none';
document.getElementById('echanges').style.display = 'none';
document.getElementById('echange').style.display = 'none';
document.getElementById('achat').style.display = 'none';
document.getElementById('deco').style.display = 'none';
document.getElementById('bleudeco').style.display = 'none';
</script>
{% endblock %}
