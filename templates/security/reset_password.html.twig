{% extends 'base.html.twig' %}

{% block title %}Nouveau mot de passe | Art et partage{% endblock %}

{% block body %}
<section class="container mt-5 mb-5" style="max-width:500px;">

    <h1 class="text-center mb-5" style="color:#2c3e50;font-weight:700;">Réinitialisation du mot de passe</h1>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-4">
            <p class="text-muted text-center mb-4">Veuillez entrer votre nouveau mot de passe ci-dessous.</p>
            <form method="post">
                <input type="hidden" name="_token" value="{{ csrf_token('reset_password') }}"> 
                <div class="mb-3">
                    <label for="inputPassword" style="font-weight:600;color:#2c3e50;">Nouveau mot de passe</label>
                    <input type="password" name="password" id="inputPassword" placeholder="Votre nouveau mot de passe" required class="form-control mt-2">
                </div>
                <input type="hidden" name="token" value="{{ token }}">
                <div class="text-center mt-4">
                    <button type="submit" class="btn btn-lg" style="background-color:#e67e22;color:white;border-radius:30px;padding:10px 30px;">
                        Valider
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="text-center">
        <a href="{{ path('security_login') }}" style="color:#2fa4e7;">Retour à la connexion</a>
    </div>

</section>
{% endblock %}