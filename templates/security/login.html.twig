{% extends 'base.html.twig' %}

{% block title %}Connexion | Art et partage{% endblock %}

{% block meta_description %}Connectez-vous à votre espace Art et partage pour échanger vos œuvres.{% endblock %}

{% block body %}
<div class="container mt-5 mb-5" style="min-height: calc(100vh - 200px);">
    <h1 class="titre text-center mb-2">Conn<span class="A_titre">e</span>xion</h1>
    <p class="text-center text-muted mb-5">Accédez à votre espace et échangez vos œuvres.</p>

    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-5">
            <div class="card p-4 p-md-5">
                <form action="{{ path('security_login') }}" method="post" class="placeho">

                    {% if error %}
                        <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                    {% endif %}

                    <div class="form-group">
                        <input placeholder="Votre email" required name="_username" type="text" class="form-control">
                    </div>

                    <div class="form-group">
                        <div style="position: relative;">
                            <input placeholder="Votre mot de passe" required name="_password" type="password" class="form-control" id="pass" style="padding-right: 40px;"/>
                            <img src="/images/closed_eye.png" id="eye" onclick="changer()" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); cursor: pointer; width: 24px; height: 24px;"/>
                        </div>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-info bouton btn-block">Se connecter</button>
                    </div>

                    <div class="text-center mt-3">
                        <a href="{{ path('forgotten_password') }}" style="font-size: 0.9rem;">Mot de passe oublié ?</a>
                    </div>

                    <p class="text-center text-muted mt-3" style="font-size: 0.9rem;">
                        Pas encore membre ? <a href="{{ path('security_registration') }}">Créer un compte</a>
                    </p>

                </form>
            </div>
        </div>
    </div>
</div>

<script>
    var e = true;
    function changer() {
        if (e) {
            document.getElementById("pass").setAttribute("type", "text");
            document.getElementById("eye").src = "/images/open_eye.png";
            e = false;
        } else {
            document.getElementById("pass").setAttribute("type", "password");
            document.getElementById("eye").src = "/images/closed_eye.png";
            e = true;
        }
    }
</script>

<script>
    document.getElementById('inscription').style.display = 'none';
    document.getElementById('connexion').style.display = 'none';
    document.getElementById('admin').style.display = 'none';
    document.getElementById('member').style.display = 'none';
    document.getElementById('deconnexion').style.display = 'none';
    document.getElementById('achats').style.display = 'none';
    document.getElementById('echange').style.display = 'none';
    document.getElementById('deco').style.display = 'none';
    document.getElementById('bleudeco').style.display = 'none';
</script>
{% endblock %}