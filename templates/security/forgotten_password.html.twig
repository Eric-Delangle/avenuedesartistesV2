{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié | Art et partage{% endblock %}

{% block body %}
<section class="container mt-5 mb-5" style="max-width:500px;">

    <h1 class="text-center mb-5" style="color:#2c3e50;font-weight:700;">Mot de passe oublié</h1>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-4">
            <p class="text-muted text-center mb-4">Entrez votre adresse email et nous vous enverrons un lien pour réinitialiser votre mot de passe.</p>
            {{ form_start(emailForm) }}
            {{ form_row(emailForm.email, {'attr': {'placeholder': 'Votre adresse email'}}) }}
            <div class="text-center mt-3">
                <button type="submit" class="btn btn-lg" style="background-color:#e67e22;color:white;border-radius:30px;padding:10px 30px;">
                    Envoyer
                </button>
            </div>
            {{ form_end(emailForm) }}
        </div>
    </div>

    <div class="text-center">
        <a href="{{ path('security_login') }}" style="color:#2fa4e7;">Retour à la connexion</a>
    </div>

</section>
{% endblock %}
